# ============================================================
# ReconAI Environment Configuration
# Copy this file to .env and fill in your keys
# ============================================================

# --- LLM Provider Keys ---
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here

# Local LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Tool Paths (auto-detected if in PATH) ---
SUBFINDER_PATH=subfinder
AMASS_PATH=amass
ASSETFINDER_PATH=assetfinder
HTTPX_PATH=httpx
DNSX_PATH=dnsx
NMAP_PATH=nmap
RUSTSCAN_PATH=rustscan
FFUF_PATH=ffuf
KATANA_PATH=katana
GAU_PATH=gau
WAYBACKURLS_PATH=waybackurls
GOWITNESS_PATH=gowitness
DNSGEN_PATH=dnsgen
ALTDNS_PATH=altdns
TRUFFLEHOG_PATH=trufflehog

# --- Rate Limiting ---
DNS_THREADS=100
HTTP_THREADS=50
FFUF_RATE=150
PORT_SCAN_RATE=1000

# --- Output ---
OUTPUT_DIR=./recon-data
LOG_LEVEL=INFO
